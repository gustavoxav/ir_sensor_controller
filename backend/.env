# ============================================
# CONFIGURAÇÃO DO BACKEND
# ============================================
# Copie este arquivo para .env e preencha os valores

# --- Servidor ---
PORT=3001

# --- Broker MQTT ---
# Insira o endereço do seu broker MQTT
# Exemplos:
#   mqtt://localhost:1883       (Mosquitto local)
#   mqtt://broker.hivemq.com    (HiveMQ público)
#   mqtt://192.168.1.100:1883   (IP local)
MQTT_BROKER_URL=mqtt://200.143.224.99:1183

# Credenciais MQTT (se aplicável)
MQTT_USER=AlunosIOT
MQTT_PASS=Brok3rIoT

# Tópico MQTT (use + como wildcard para múltiplas salas)
MQTT_TOPIC=sala/+/ocupacao

# --- Banco de Dados ---
# Caminho do arquivo SQLite (relativo à raiz do backend)
DB_PATH=./data/occupancy.db
